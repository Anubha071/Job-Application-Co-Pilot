# 🔑 Secret key for JWT token encoding. Generate a strong random key.
#   You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_key_change_this_in_production

# 🔐 JWT algorithm (do not change unless you know what you're doing)
ALGORITHM=HS256

# ⏱ Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 🗄 Database URL (SQLite by default — no setup needed)
#    For PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./jobcopilot.db

# 🤖 Groq API key for LLM agents (get one at https://console.groq.com)
#    The app uses llama-3.3-70b-versatile by default
GROQ_API_KEY=gsk_your_groq_api_key_here